# ─── CoFoundry Server — Environment Variables ────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env or any file containing real secrets.

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/cofoundry?retryWrites=true&w=majority

# Port the server listens on
PORT=5000

# Client origin for CORS (no trailing slash)
CLIENT_URL=http://localhost:3000

# ── JWT (custom app-level token, NOT Better Auth session) ─────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# ── Better Auth ───────────────────────────────────────────────────
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:5000

# ── Google OAuth (via Better Auth) ───────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# Premium plan prices (in cents)
STRIPE_PRICE_MONTHLY=1200
STRIPE_PRICE_ANNUAL=9900
